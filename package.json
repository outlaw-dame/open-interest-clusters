{
  "name": "@memory/open-interest-clusters",
  "version": "0.1.0",
  "description": "Portable schema, dataset, validation, normalization, and runtime helpers for canonical hashtag interest clusters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schema/interest-cluster.schema.json",
    "./datasets/global-v1": "./datasets/interests.global.v1.json"
  },
  "files": [
    "dist",
    "schema",
    "datasets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "validate:dataset": "tsx scripts/validate-dataset.ts datasets/interests.global.v1.json",
    "normalize:dataset": "tsx scripts/normalize-dataset.ts datasets/interests.global.v1.json",
    "prepare": "npm run build"
  },
  "keywords": [
    "fediverse",
    "mastodon",
    "activitypub",
    "atproto",
    "hashtags",
    "recommendations",
    "json-schema"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
